#!/usr/bin/env python3
"""Auto-generated rubric scorer for ${rubric_name}.

Emitted by the grading-rubric skill on ${iso_generated_at}.
Mode: ${mode}

Contract (consumed by /auto researcher and any compatible loop):
  - Reads outputs from $$RUBRIC_OUTPUTS_DIR (default: ./outputs/).
  - Reads optional runtime measurement from $$RUBRIC_OUTPUTS_DIR/runtime_seconds.txt
    (used by the regression_trip_wire's runtime_exceeded check).
  - Prints exactly one line on success:  composite: <float in [0, 1]>
  - Exits 0 on success, 1 on any hard-gate failure or scoring error.
  - On hard-gate failure, writes  GATE_FAILED: <gate_name>: <reason>  to stderr
    so the failure surfaces in /auto researcher's EXPERIMENT_LOG.md crash row.
  - Stdlib only -- runs anywhere Python 3.11+ runs, no extra installs.

Per-mode input conventions:
  - deterministic: $$RUBRIC_OUTPUTS_DIR/scores.json with {criterion_name: float} mapping.
  - llm_judge:     $$RUBRIC_OUTPUTS_DIR/${main_output_filename} (the artifact to judge),
                   plus env vars RUBRIC_LLM_ENDPOINT, RUBRIC_LLM_API_KEY.

You may edit this file, but if you regenerate the rubric you must regenerate the
scorer too -- the criteria array is embedded as a Python literal below and must
stay in sync with the source RUBRIC.md.
"""

from __future__ import annotations

import json
import os
import sys
from pathlib import Path

# === EMITTED CONFIG (skill substitutes these placeholders at emit time) ===
RUBRIC_NAME: str = "${rubric_name}"
MODE: str = "${mode}"  # "deterministic" or "llm_judge"
TRIP_WIRE_ENABLED: bool = ${trip_wire_enabled_python}
BASELINE_RUNTIME_SECONDS: float | None = ${baseline_runtime_seconds_or_none}
MAIN_OUTPUT_FILENAME: str = "${main_output_filename}"
EXPECTED_FORMAT: str = "${expected_format}"  # "text" or "json"
CRITERIA: list[dict] = ${criteria_python_literal}
# === END EMITTED CONFIG ===


# ---------------------------------------------------------------------------
# Trip-wire: runs before any criterion scoring.  Catches catastrophic outputs
# (empty / NaN / runaway runtime / structurally invalid) so the agent can't
# accidentally optimize toward a degenerate shortcut.
# ---------------------------------------------------------------------------

# Tokens that strongly indicate the output is a stack trace or NaN-poisoned
# numerical artifact.  Order matters slightly: longer, more specific tokens
# first so the reported reason is informative.
_NAN_OR_ERROR_TOKENS: tuple[str, ...] = (
    "Traceback (most recent call last)",
    "NaN",
    "Infinity",
    "Error:",
    "Exception:",
)


def check_trip_wire(output_path: Path, runtime_seconds: float) -> tuple[str, str] | None:
    """Run the four trip-wire checks; return (gate_name, reason) on first failure, else None."""
    if not output_path.exists() or output_path.stat().st_size == 0:
        return (
            "regression_trip_wire.empty_output",
            f"{output_path} is missing or 0 bytes",
        )
    try:
        text = output_path.read_text(encoding="utf-8", errors="replace")
    except OSError as e:
        return ("regression_trip_wire.empty_output", f"could not read {output_path}: {e}")

    for token in _NAN_OR_ERROR_TOKENS:
        if token in text:
            return (
                "regression_trip_wire.nan_or_error",
                f"output contains forbidden token: {token!r}",
            )

    if BASELINE_RUNTIME_SECONDS is not None and runtime_seconds > 10 * BASELINE_RUNTIME_SECONDS:
        return (
            "regression_trip_wire.runtime_exceeded",
            f"runtime {runtime_seconds:.1f}s exceeded 10x baseline ({BASELINE_RUNTIME_SECONDS:.1f}s)",
        )

    if EXPECTED_FORMAT == "json":
        try:
            json.loads(text)
        except json.JSONDecodeError as e:
            return (
                "regression_trip_wire.structure_invalid",
                f"output is not valid JSON: {e}",
            )

    return None


# ---------------------------------------------------------------------------
# Mode-specific scoring functions.  The grading-rubric skill strips ONE of the
# two `# === BEGIN/END MODE: ... ===` blocks below at emit time so the
# delivered scorer.py contains only the chosen mode's code.
# ---------------------------------------------------------------------------

# === BEGIN MODE: deterministic ===
# Deterministic mode: the user's run_command writes scores.json with per-criterion
# floats already computed.  The scorer just reads, validates, and aggregates.
def score_criteria(outputs_dir: Path) -> dict[str, float]:
    scores_path = outputs_dir / "scores.json"
    if not scores_path.exists():
        raise RuntimeError(
            f"deterministic mode requires {scores_path} (per-criterion scores as JSON object)"
        )
    raw = scores_path.read_text(encoding="utf-8")
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        raise RuntimeError(f"{scores_path} is not valid JSON: {e}") from e
    if not isinstance(data, dict):
        raise RuntimeError(f"{scores_path} must be an object mapping criterion name -> float")

    out: dict[str, float] = {}
    for c in CRITERIA:
        name = c["name"]
        if name == "regression_trip_wire":
            continue
        if name not in data:
            raise RuntimeError(f"{scores_path} missing score for criterion '{name}'")
        try:
            out[name] = float(data[name])
        except (TypeError, ValueError) as e:
            raise RuntimeError(
                f"{scores_path}['{name}'] is not a float: {data[name]!r}"
            ) from e
    return out
# === END MODE: deterministic ===


# === BEGIN MODE: llm_judge ===
# LLM-judge mode: the user's run_command writes the main output artifact; this
# scorer asks an LLM to score each criterion, averaging N=3 calls per criterion
# at temperature=0 with a fixed seed where supported.  Stdlib only -- uses
# urllib.request, no `requests` dependency.
import urllib.request  # noqa: E402

LLM_ENDPOINT: str = os.environ.get("RUBRIC_LLM_ENDPOINT", "")
LLM_API_KEY: str = os.environ.get("RUBRIC_LLM_API_KEY", "")
LLM_MODEL: str = os.environ.get("RUBRIC_LLM_MODEL", "${llm_model_default}")
N_SAMPLES: int = 3
ADVERSARIAL_PERSONA: str = """${adversarial_persona}"""


def _llm_call(prompt: str) -> str:
    """One LLM call against an OpenAI-compatible chat-completions endpoint.

    If your provider has a different response shape, edit the parser in the
    ``return`` statement.  Defaults: temperature=0, seed=42 for reproducibility.
    """
    if not LLM_ENDPOINT or not LLM_API_KEY:
        raise RuntimeError(
            "llm_judge mode requires env vars RUBRIC_LLM_ENDPOINT and RUBRIC_LLM_API_KEY."
        )
    payload = json.dumps(
        {
            "model": LLM_MODEL,
            "messages": [{"role": "user", "content": prompt}],
            "temperature": 0,
            "seed": 42,
        }
    ).encode("utf-8")
    req = urllib.request.Request(
        LLM_ENDPOINT,
        data=payload,
        headers={
            "Content-Type": "application/json",
            "Authorization": f"Bearer {LLM_API_KEY}",
        },
    )
    with urllib.request.urlopen(req, timeout=60) as resp:  # noqa: S310 (URL is user-configured)
        data = json.loads(resp.read().decode("utf-8"))
    return data["choices"][0]["message"]["content"]


def _parse_score(text: str) -> float:
    """Look for a ``Score: <float>`` line near the end of the response."""
    for line in reversed(text.strip().splitlines()):
        s = line.strip()
        if s.lower().startswith("score:"):
            try:
                return float(s.split(":", 1)[1].strip())
            except ValueError:
                continue
    raise RuntimeError(f"Could not parse 'Score: <float>' from LLM response:\n{text}")


def score_criteria(outputs_dir: Path) -> dict[str, float]:
    output_text = (outputs_dir / MAIN_OUTPUT_FILENAME).read_text(
        encoding="utf-8", errors="replace"
    )
    out: dict[str, float] = {}
    for c in CRITERIA:
        name = c["name"]
        if name == "regression_trip_wire":
            continue
        prompt = (
            f"You are evaluating an output as the following reviewer:\n"
            f"{ADVERSARIAL_PERSONA}\n\n"
            f"Score the output against this criterion:\n"
            f"  Name: {name}\n"
            f"  Definition: {c['definition']}\n"
            f"  What 9/10 looks like: {c['what_9_of_10_looks_like']}\n\n"
            f"OUTPUT TO EVALUATE:\n---\n{output_text}\n---\n\n"
            f"Respond with one short paragraph of analysis, then a final line:\n"
            f"Score: <float in [0, 1]>"
        )
        samples = [_parse_score(_llm_call(prompt)) for _ in range(N_SAMPLES)]
        out[name] = sum(samples) / len(samples)
    return out
# === END MODE: llm_judge ===


# ---------------------------------------------------------------------------
# Composite aggregation: weighted arithmetic mean across non-hard-gate criteria,
# with hard-gate failures reported separately so the loop sees them as crashes,
# not as low scores.
# ---------------------------------------------------------------------------


def compute_composite(scores: dict[str, float]) -> tuple[float, list[tuple[str, str]]]:
    """Aggregate per-criterion scores into a single composite plus any gate failures."""
    weighted_sum = 0.0
    weight_total = 0.0
    gate_fails: list[tuple[str, str]] = []
    for c in CRITERIA:
        name = c["name"]
        if name == "regression_trip_wire":
            continue
        score = max(0.0, min(1.0, scores[name]))  # clamp into [0, 1] defensively
        if c.get("hard_gate"):
            if score < c.get("threshold", 0.5):
                reason = c.get(
                    "fail_reason",
                    f"score {score:.3f} below threshold {c.get('threshold')}",
                )
                gate_fails.append((name, reason))
        else:
            weighted_sum += float(c["weight"]) * score
            weight_total += float(c["weight"])
    composite = weighted_sum / weight_total if weight_total > 0 else 0.0
    return composite, gate_fails


def main() -> int:
    outputs_dir = Path(os.environ.get("RUBRIC_OUTPUTS_DIR", "outputs"))
    if not outputs_dir.is_dir():
        print(
            f"GATE_FAILED: scorer.outputs_dir_missing: {outputs_dir} does not exist",
            file=sys.stderr,
        )
        return 1

    main_output = outputs_dir / MAIN_OUTPUT_FILENAME
    runtime_path = outputs_dir / "runtime_seconds.txt"
    runtime_seconds = 0.0
    if runtime_path.exists():
        try:
            runtime_seconds = float(runtime_path.read_text(encoding="utf-8").strip())
        except (OSError, ValueError):
            # If the user's pipeline didn't write a parseable runtime, treat as
            # 0 -- the runtime trip-wire check will simply not fire.
            runtime_seconds = 0.0

    if TRIP_WIRE_ENABLED:
        tw = check_trip_wire(main_output, runtime_seconds)
        if tw is not None:
            gate_name, reason = tw
            print(f"GATE_FAILED: {gate_name}: {reason}", file=sys.stderr)
            return 1

    try:
        scores = score_criteria(outputs_dir)
    except RuntimeError as e:
        print(f"GATE_FAILED: scorer.scoring_error: {e}", file=sys.stderr)
        return 1

    composite, gate_fails = compute_composite(scores)
    if gate_fails:
        for name, reason in gate_fails:
            print(f"GATE_FAILED: {name}: {reason}", file=sys.stderr)
        return 1

    print(f"composite: {composite:.6f}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
