{
  "name": "perplexity_reason",
  "description": "Analyze a question using step-by-step reasoning with web grounding (Sonar Reasoning Pro model). For comprehensive multi-source research, use perplexity_research instead.",
  "arguments": {
    "type": "object",
    "properties": {
      "messages": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "role": {
              "type": "string",
              "enum": ["system", "user", "assistant"]
            },
            "content": { "type": "string" }
          },
          "required": ["role", "content"],
          "additionalProperties": false
        }
      },
      "strip_thinking": { "type": "boolean" },
      "search_recency_filter": {
        "type": "string",
        "enum": ["hour", "day", "week", "month", "year"]
      },
      "search_domain_filter": {
        "type": "array",
        "items": { "type": "string" }
      },
      "search_context_size": { "type": "string", "enum": ["low", "medium", "high"] }
    },
    "required": ["messages"],
    "additionalProperties": false
  }
}
