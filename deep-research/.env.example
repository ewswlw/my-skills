# OPTIONAL: only if you do NOT set the key in User/system environment.
# Preferred: set PERPLEXITY_API_KEY once in Windows "Environment variables" (same as
# C:\Users\Eddy\.cursor\mcp.json -> perplexity -> ${env:PERPLEXITY_API_KEY}) so MCP and this script share it.
# Get / rotate keys: https://docs.perplexity.ai/getting-started/api-groups
PERPLEXITY_API_KEY=
# Default model for long research (overridable)
PERPLEXITY_MODEL=sonar-deep-research
# Optional: for sonar-deep-research only (low|medium|high)
PERPLEXITY_REASONING_EFFORT=medium

# Optional overrides (see scripts/research.py)
# DEEP_RESEARCH_PERPLEXITY_TIMEOUT=120
# DEEP_RESEARCH_FALLBACK_TIMEOUT=60
