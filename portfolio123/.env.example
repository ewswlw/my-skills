# Portfolio123 DataMiner API (required for data_pull / factor_upload)
P123_API_ID=
P123_API_KEY=

# Optional: CSV/JSON output directory (default: ~/Documents/Obsidian Vault/p123-output)
# P123_OUTPUT_DIR=

# Optional: Obsidian vault root for src.data_validation when P123_RUN_VALIDATION=1
# OBSIDIAN_VAULT=

# Optional: chrome-cdp cdp.mjs path
# CDP_SCRIPT=

# Optional: set to 1 to run vault validate() on pulled panels (may require schema tuning)
# P123_RUN_VALIDATION=0
